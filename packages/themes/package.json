{
  "name": "@ultraviolet/themes",
  "version": "3.1.6",
  "description": "Ultraviolet Themes",
  "keywords": [
    "themes",
    "ui"
  ],
  "homepage": "https://github.com/scaleway/ultraviolet#readme",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scaleway/ultraviolet.git",
    "directory": "packages/themes"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.css.ts"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json",
    "./global.css": "./dist/global.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "tsdown": "tsdown",
    "build": "vite build  && pnpm run type:generate",
    "build:profile": "npx vite-bundle-visualizer -c vite.config.ts",
    "lintpublish": "pnpm publint",
    "type:generate": "tsgo --declaration -p tsconfig.build.json",
    "typecheck": "tsgo --noEmit",
    "watch": "pnpm run '/^watch:.*/'",
    "watch:build": "vite build  --watch"
  },
  "dependencies": {
    "@vanilla-extract/css": "1.20.1",
    "@vanilla-extract/dynamic": "2.1.5"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "vite": "8.0.12"
  },
  "peerDependencies": {
    "react": "18.x || 19.x",
    "react-dom": "18.x || 19.x"
  },
  "engines": {
    "node": ">=18.x",
    "pnpm": ">=9.x"
  }
}
