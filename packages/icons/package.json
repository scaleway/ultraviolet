{
  "name": "@ultraviolet/icons",
  "version": "5.3.3",
  "description": "Ultraviolet Icons",
  "keywords": [
    "react",
    "reactjs",
    "ui"
  ],
  "homepage": "https://github.com/scaleway/ultraviolet#readme",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scaleway/ultraviolet.git",
    "directory": "packages/icons"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.css.ts"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./components/CategoryIcon": "./dist/components/CategoryIcon/index.js",
    "./components/Flags": "./dist/components/Flags/index.js",
    "./components/Logo": "./dist/components/Logo/index.js",
    "./components/ProductIcon": "./dist/components/ProductIcon/index.js",
    "./iconStyles": "./dist/iconStyles.js",
    "./package.json": "./package.json",
    "./assets/src/components/CategoryIcon/style.css.ts.vanilla-BtXw4hOz.css": "./dist/assets/src/components/CategoryIcon/style.css.ts.vanilla-BtXw4hOz.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "tsdown": "tsdown",
    "build": "vite build  && pnpm run type:generate",
    "build:profile": "npx vite-bundle-visualizer -c vite.config.ts",
    "lintpublish": "publint",
    "size": "size-limit",
    "test:unit": "LC_ALL=en_US.UTF-8 pnpm vitest --run ",
    "type:generate": "tsgo --declaration -p tsconfig.build.json",
    "typecheck": "tsgo --noEmit",
    "watch": "pnpm run '/^watch:.*/'",
    "watch:build": "vite build  --watch"
  },
  "dependencies": {
    "@ultraviolet/themes": "workspace:*",
    "@ultraviolet/utils": "workspace:*",
    "@vanilla-extract/css": "1.20.1",
    "@vanilla-extract/dynamic": "2.1.5",
    "@vanilla-extract/recipes": "0.5.7"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@repo/config": "workspace:*",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@utils/test": "workspace:*",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "vite": "8.0.12"
  },
  "peerDependencies": {
    "react": "18.x || 19.x",
    "react-dom": "18.x || 19.x"
  },
  "size-limit": [
    {
      "path": [
        "dist/**/*.js",
        "!*.d.ts",
        "!*.cjs"
      ],
      "limit": "1000 kB",
      "webpack": false,
      "brotli": true,
      "running": false
    }
  ],
  "engines": {
    "node": ">=18.x",
    "pnpm": ">=9.x"
  }
}
