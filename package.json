{
  "name": "root",
  "private": true,
  "os": [
    "darwin",
    "linux"
  ],
  "type": "module",
  "scripts": {
    "preinstall": "git config --local include.path $PWD/.gitconfig || true",
    "analyse:deps:form": "tsx ./utils/scripts/analyse-deps.ts packages/form/src/components",
    "analyse:deps:ui": "tsx ./utils/scripts/analyse-deps.ts packages/ui/src/components",
    "analyse:dist": "tsx ./utils/scripts/compare/compare-dist-migration.ts",
    "build": "turbo run build --filter='./packages/*' ",
    "build:examples": "turbo run build --filter './examples/*' ",
    "build:storybook": "STORYBOOK_ENVIRONMENT=production storybook build",
    "build:storybook:stats": "pnpm turbo build:storybook -- --webpack-stats-json",
    "check:deps": "npx depcheck . --skip-missing=true --ignores='vite,@commitlint/*'",
    "commit": "npx git-cz -a --disable-emoji",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "icons:update": "tsx ./utils/scripts/generate-icons-file.tsx && pnpm run format packages/icons",
    "illustrations:update": "BUCKET_NAME=scaleway-assets BUCKET_REGION=fr-par tsx utils/scripts/illustrations/update-illustrations.tsx && pnpm format packages/illustrations/src/",
    "lint:fix": "pnpm run oxc:type-aware --fix && pnpm run oxc:lint",
    "lintpublish": "turbo run lintpublish",
    "oxc": "oxlint -c .oxlintrc.jsonc",
    "oxc:fix": "pnpm run oxc --fix",
    "oxc:lint": "pnpm -w oxlint -c .oxlintrc.jsonc",
    "oxc:type-aware": "oxlint -c .oxlintrc.jsonc --type-aware",
    "release": "pnpm build && pnpm changeset publish",
    "size": "turbo run size",
    "start": "STORYBOOK_ENVIRONMENT=development storybook dev -p 6006",
    "start:production": "STORYBOOK_ENVIRONMENT=production storybook dev -p 6006",
    "svg": "svgo --config=./svgo.config.mjs --pretty --multipass",
    "svg:all": "pnpm run svg -r -f 'packages/illustrations/src/assets'",
    "test:e2e": "turbo e2e --filter @repo/e2e",
    "test:unit": "turbo run test:unit",
    "test:unit:coverage": "turbo run test:unit:coverage",
    "tokens:update": "tsx ./utils/scripts/figma-synchronise-token/index.ts && pnpm run format packages/themes/src/themes/console",
    "typecheck": "turbo run typecheck",
    "typecheck:root": "tsgo -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@manypkg/cli": "0.25.1",
    "@playwright/test": "1.59.1",
    "@scaleway/oxfmt-config": "1.1.3",
    "@scaleway/oxlint-config": "0.1.15",
    "@scaleway/tsconfig": "1.1.4",
    "@size-limit/file": "12.1.0",
    "@size-limit/preset-big-lib": "12.1.0",
    "@storybook/addon-a11y": "10.3.6",
    "@storybook/addon-docs": "10.3.6",
    "@storybook/addon-links": "10.3.6",
    "@storybook/addon-themes": "10.3.6",
    "@storybook/builder-vite": "10.3.6",
    "@storybook/mdx2-csf": "1.1.0",
    "@storybook/react-vite": "10.3.6",
    "@svgr/rollup": "8.1.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.12.4",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/zxcvbn": "4.4.5",
    "@typescript/native-preview": "7.0.0-dev.20260521.1",
    "@ultraviolet/fonts": "workspace:*",
    "@ultraviolet/themes": "workspace:*",
    "@ultraviolet/ui": "workspace:*",
    "@vanilla-extract/css": "1.20.1",
    "@vanilla-extract/vite-plugin": "5.2.2",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-istanbul": "4.1.5",
    "@vitest/coverage-v8": "4.1.5",
    "@vitest/ui": "4.1.5",
    "browserslist": "4.28.2",
    "cross-env": "10.1.0",
    "cz-conventional-changelog": "3.3.0",
    "date-fns": "4.1.0",
    "expect": "30.3.0",
    "file-loader": "6.2.0",
    "globals": "17.6.0",
    "happy-dom": "20.9.0",
    "jest-axe": "10.0.0",
    "jsdom": "29.1.1",
    "lint-staged": "16.4.0",
    "oxfmt": "0.49.0",
    "oxlint": "1.64.0",
    "oxlint-tsgolint": "0.23.0",
    "postcss": "8.5.15",
    "publint": "0.3.20",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-scan": "0.5.6",
    "read-pkg": "10.1.0",
    "regenerator-runtime": "0.14.1",
    "remark-gfm": "4.0.1",
    "rollup-preserve-directives": "1.1.3",
    "size-limit": "12.1.0",
    "storybook": "10.3.6",
    "storybook-addon-tag-badges": "3.1.0",
    "svgo": "4.0.1",
    "timekeeper": "2.3.1",
    "tsx": "4.21.0",
    "turbo": "2.9.14",
    "typescript": "6.0.3",
    "vite": "8.0.13",
    "vitest": "4.1.5",
    "vitest-axe": "0.1.0",
    "vitest-canvas-mock": "1.1.4",
    "vitest-localstorage-mock": "0.1.2",
    "zxcvbn": "4.4.2"
  },
  "lint-staged": {
    "*.(j|t|mj)s?(x)": [
      "pnpm run format",
      "pnpm run oxc:lint"
    ],
    "packages/illustrations/**/*.svg": [
      "pnpm run svg"
    ],
    "*.y?(a)ml": [
      "pnpm run format"
    ],
    "*.json?(c)": [
      "pnpm run format"
    ],
    ".md?(x)": [
      "pnpm run format"
    ],
    "pnpm-lock.yaml, package.json, **/pnpm-lock.yaml, **/package.json": [
      "pnpm exec manypkg check"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "engines": {
    "node": ">=20.x",
    "pnpm": ">=10.x"
  },
  "packageManager": "pnpm@11.2.2",
  "manypkg": {
    "ignoredRules": [
      "INTERNAL_MISMATCH"
    ]
  }
}
